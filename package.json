{
	"name": "dnd-pwa",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"bun": ">=1.0.0"
	},
	"scripts": {
		"dev": "bun run --shell bun --cwd grimar dev",
		"build": "bun run --shell bun --cwd grimar build",
		"preview": "bun run --shell bun --cwd grimar preview",
		"start": "bun run --shell bun --cwd grimar start",
		"prepare": "bun run --shell bun --cwd grimar prepare",
		"check": "bun run --shell bun --cwd grimar check",
		"check:watch": "bun run --shell bun --cwd grimar check:watch",
		"format": "bun run --shell bun --cwd grimar format",
		"lint": "bun run --shell bun --cwd grimar lint",
		"test": "bun run --shell bun --cwd grimar test",
		"test:ui": "bun run --shell bun --cwd grimar test:ui",
		"test:run": "bun run --shell bun --cwd grimar test:run",
		"test:e2e": "bun run --shell bun --cwd grimar test:e2e",
		"test:e2e:ui": "bun run --shell bun --cwd grimar test:e2e:ui",
		"test:e2e:debug": "bun run --shell bun --cwd grimar test:e2e:debug",
		"test:all": "bun run --shell bun --cwd grimar test:all",
		"db:push": "bun run --shell bun --cwd grimar db:push",
		"db:generate": "bun run --shell bun --cwd grimar db:generate",
		"db:migrate": "bun run --shell bun --cwd grimar db:migrate",
		"db:studio": "bun run --shell bun --cwd grimar db:studio",
		"db:sync": "bun run --shell bun --cwd grimar db:sync",
		"reindex-fts": "bun run --shell bun --cwd grimar reindex-fts"
