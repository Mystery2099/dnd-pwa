DATABASE_URL=local.db
NODE_ENV=development
VITE_MOCK_USER=

# Open5e API (self-hosted)
OPEN5E_API_BASE_URL=http://10.147.20.240:8888/v2
OPEN5E_SYNC_BATCH_SIZE=100

# Development-only auth bypass for E2E (requires test-user cookie or X-Authentik-Username header)
DEV_TEST_AUTH_BYPASS=false

# Optional comma-separated Authentik groups that should be treated as app admins
ADMIN_GROUPS=

# Optional shared token for POST /api/cache/invalidate
ADMIN_SYNC_TOKEN=

# Authentik OAuth2
AUTHENTIK_URL=https://auth.grimar.win
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URI=http://localhost:5173/auth/callback

# Required in production; development falls back to a temporary key if omitted
SESSION_ENCRYPTION_KEY=
